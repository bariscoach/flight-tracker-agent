# Copy this file to .env and fill in your values before running locally.

# Anthropic API key — get from https://console.anthropic.com
ANTHROPIC_API_KEY=

# Gmail credentials for sending the digest email
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=

# Google Cloud / Firestore
FIRESTORE_KEY_PATH=firestore-key.json   # path to service-account JSON on disk
FIRESTORE_PROJECT=flight-tracker        # GCP project ID
